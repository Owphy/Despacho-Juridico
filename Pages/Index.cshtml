@page
@{
    ViewData["Title"] = "Home Page";
}

<!-- SECCIÓN 1: Primera imagen fija -->
<!-- Contenedor Padre -->
<div class="pantalla-principal">

    <!-- 1. Capa de Filtro Oscuro (el fondo ahora se aplica vía CSS en .pantalla-principal) -->
    <div class="capa-filtro"></div>

    <!-- 3. Contenedor Flexbox de Alineación -->
    <div class="contenedor-alineacion">
        <!-- Tu caja de texto dorada -->
        <div class="caja-dorada">
            <h1 class="titulo-principal">Bienvenidos</h1>
            <h2 class="subtitulo-principal">Abogados con Humanidades</h2>
            <p class="texto-tranquilidad">Trabajamos para tu tranquilidad</p>
        </div>
    </div>

</div>

<!-- SECCIÓN 2: Apartado blanco intermedio -->
<div class="NuestraMision" id="NuestraMision">
    <div class="contenedor0">
        <div class="contenido-blanco">
            <h2 class="mision">Nuestra Misión</h2>
            <p class="misionDescripcion">
                Nos encargaremos de guiar y proteger a las familias en sus momentos de transición más difíciles. Brindamos una representación legal firme,
                honesta y compasiva en procesos de divorcio y derecho familiar, priorizando el bienestar de los hijos y buscando soluciones
                justas que permitan a nuestros clientes construir un futuro seguro y en paz.
            </p>
        </div>
    </div>
    <!--Separador-->
    <div class="separador-identidad">
        <span>Nuestra Identidad</span>
    </div>

    <!-- Fila de Contenedores (Flexbox) -->
    <div class="fila-tarjetas">

        <!-- Tarjeta Izquierda: Valores (Azul Oscuro) -->
        <div class="tarjeta-valores">
            <h5>Nuestros Valores</h5>
            <ul>
                <li>Especialista en Derecho y Familia.</li>
                <li>Especialista en Derecho y Mediación.</li>
                <li>Comprometida con soluciones humanas.</li>
            </ul>
        </div>

        <!-- Botón Central de Contacto -->
        <div class="contenedor-boton-central">
            <a asp-area="" asp-page="/Contacto" class="btn-contacto-directo">CONTACTO</a>
        </div>

        <!-- Tarjeta Derecha: Objetivos (Terracota / Marrón Cálido) -->
        <div class="tarjeta-objetivos">
            <h3>Nuestros Objetivos</h3>
            <ol>
                <li><span>1.</span> Defender tu dignidad y derechos humanos.</li>
                <li><span>2.</span> Buscar una justicia real y equitativa.</li>
                <li><span>3.</span> Darte una defensa firme y sin miedo.</li>
            </ol>

            <!-- Icono o Lámpara Dorada flotante decorativa -->
            <div class="lampara-decorativa"></div>
        </div>

    </div>

</div>
