<!DOCTYPE html>
<html lang="es" class="h-100" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DespachoJuridico</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DespachoJuridico.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div class="mi-navbar">
            <nav class="navbar navbar-expand-lg navbar-dark navbar-traslucida">
                <!-- Cambié container-fluid por container para que herede el margen elegante de tu web -->
                <div class="container">

                    <!-- 1. BLOQUE IZQUIERDO: El logo de tu marca -->
                    <a class="navbar-brand" asp-page="/Index">
                        <img src="~/Images/Logo.png" alt="Bootstrap" width="60" height="60">
                    </a>

                    <!-- 2. BOTÓN DE CELULAR: Va suelto (sin envolver) para que Bootstrap lo mande a la derecha en móviles -->
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <!-- 3. BLOQUE DERECHO: El menú colapsable libre de envolturas -->
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <!-- Usamos 'ms-auto' para empujar magnéticamente todos los enlaces a la derecha -->
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link active text-white" aria-current="page" asp-page="/Index" asp-fragment="NuestraMision">Nosotros</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-page="/Servicios">Servicios</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-area="" asp-page="/Contacto">Contacto</a>
                            </li>
                        </ul>
                    </div>

                </div>
            </nav>
        </div>
    </header>


    <div class="container flex-grow-1">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="container-pie-pagina border-top text-muted">

        &copy; 2026 - DespachoJuridico - <a>Privacy</a>

    </footer>

    <!-- Botón flotante: Volver arriba -->
    <button id="btnScrollTop" class="btn-scroll-top" aria-label="Volver arriba" title="Volver arriba">
        <i class="bi bi-arrow-up"></i>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
            (function() {
                const btnScrollTop = document.getElementById('btnScrollTop');

                // Muestra el botón solo después de bajar 300px
                window.addEventListener('scroll', function() {
                    if (window.scrollY > 300) {
                        btnScrollTop.classList.add('visible');
                    } else {
                        btnScrollTop.classList.remove('visible');
                    }
                });

                // Sube suavemente hasta el inicio al hacer clic
                btnScrollTop.addEventListener('click', function() {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
