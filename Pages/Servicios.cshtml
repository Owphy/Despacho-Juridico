@page
@model ServiciosModel
@{
    ViewData["Title"] = "Servicios";
}

<div class="serviciosContainer">
    <div class="servicios-main-content">

        <!-- Cabecera -->
        <div class="servicios-header">
            <h1 class="servicios-title">Nuestros Servicios</h1>
            <p class="servicios-subtitle">
                Ofrecemos representación legal firme y humana en cada etapa del proceso,
                acompañándote con soluciones claras y personalizadas.
            </p>
        </div>

        <!-- CATEGORÍA: Derecho Familiar -->
        <div class="servicios-category-section">
            <h2 class="category-title">Derecho Familiar</h2>
            <div class="servicios-grid">

                <!-- Divorcio y Separación -->
                <div class="servicio-card">
                    <div class="servicio-icon-badge badge-divorcio">
                        <i class="fa-solid fa-scale-balanced"></i>
                    </div>
                    <h3 class="servicio-card-title">Divorcio y Separación</h3>
                    <p class="servicio-card-text">
                        Asesoría integral para divorcios contenciosos y de mutuo acuerdo.
                    </p>
                    <a asp-page="/Index" asp-fragment="contacto" class="servicio-btn">CONSULTAR</a>
                </div>

                <!-- Custodia y Visitas -->
                <div class="servicio-card">
                    <div class="servicio-icon-badge badge-custodia">
                        <i class="fa-solid fa-scale-balanced"></i>
                    </div>
                    <h3 class="servicio-card-title">Custodia y Visitas</h3>
                    <p class="servicio-card-text">
                        Establecimiento de acuerdos de custodia que priorizan el bienestar de los hijos.
                    </p>
                    <a asp-page="/Index" asp-fragment="contacto" class="servicio-btn">CONSULTAR</a>
                </div>

                <!-- Pensión Alimenticia -->
                <div class="servicio-card">
                    <div class="servicio-icon-badge badge-pension">
                        <i class="fa-solid fa-scale-balanced"></i>
                    </div>
                    <h3 class="servicio-card-title">Pensión Alimenticia</h3>
                    <p class="servicio-card-text">
                        Cálculo y solicitud de pensión alimenticia justa y equitativa para tu familia.
                    </p>
                    <a asp-page="/Index" asp-fragment="contacto" class="servicio-btn">CONSULTAR</a>
                </div>

            </div>
        </div>

        <!-- CATEGORÍA: Derecho Laboral -->
        <div class="servicios-category-section">
            <h2 class="category-title">Derecho Laboral</h2>
            <div class="servicios-grid">

                <!-- Despido Injustificado -->
                <div class="servicio-card">
                    <div class="servicio-icon-badge badge-despido">
                        <i class="fa-solid fa-gavel"></i>
                    </div>
                    <h3 class="servicio-card-title">Despido Injustificado</h3>
                    <p class="servicio-card-text">
                        Defensa y reclamo de indemnizaciones ante despidos sin causa justificada.
                    </p>
                    <a asp-page="/Index" asp-fragment="contacto" class="servicio-btn">CONSULTAR</a>
                </div>

                <!-- Asesoría en Contratos -->
                <div class="servicio-card">
                    <div class="servicio-icon-badge badge-contratos">
                        <i class="fa-solid fa-scale-balanced"></i>
                    </div>
                    <h3 class="servicio-card-title">Asesoría en Contratos</h3>
                    <p class="servicio-card-text">
                        Revisión y elaboración de contratos laborales que protegen tus derechos.
                    </p>
                    <a asp-page="/Index" asp-fragment="contacto" class="servicio-btn">CONSULTAR</a>
                </div>

                <!-- Pensiones IMSS -->
                <div class="servicio-card">
                    <div class="servicio-icon-badge badge-pensiones-imss">
                        <i class="fa-solid fa-scale-balanced"></i>
                    </div>
                    <h3 class="servicio-card-title">Pensiones IMSS</h3>
                    <p class="servicio-card-text">
                        Trámite y gestión de pensiones ante el IMSS con acompañamiento legal.
                    </p>
                    <a asp-page="/Index" asp-fragment="contacto" class="servicio-btn">CONSULTAR</a>
                </div>

            </div>
        </div>

    </div>
</div>
